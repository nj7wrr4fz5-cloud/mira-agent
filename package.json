{
  "name": "mira-agent",
  "version": "1.0.0",
  "description": "AI Agent Desktop App - Connect with Mira AI. Schedule messages, manage groups & bots, auto-updates via GitHub releases.",
  "main": "dist/main/main.js",
  "author": "Mira AI",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \\\"npm run dev:renderer\\\" \\\"npm run dev:main\\\"",
    "dev:renderer": "vite",
    "dev:main": "tsc -p tsconfig.main.json && electron .",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "package": "npm run build && electron-builder --win --x64",
    "package:portable": "npm run build && electron-builder --win --x64 --portable"
  },
  "dependencies": {
    "electron-log": "^5.2.0",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.1.0",
    "node-cron": "^3.0.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "recharts": "^2.10.0",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  },
  "build": {
    "appId": "com.mira.agent",
    "productName": "Mira Agent",
    "directories": { "output": "release" },
    "files": ["dist/**/*", "package.json"],
    "win": { 
      "target": [
        {"target": "portable", "arch": ["x64"]},
        {"target": "dir", "arch": ["x64"]}
      ] 
    },
    "portable": { "artifactName": "Mira-Agent-Portable.exe" },
    "publish": { "provider": "github", "owner": "nj7wrr4fz5-cloud", "repo": "mira-agent" }
  }
}
